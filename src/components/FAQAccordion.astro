---
interface Props {
  question: string;
  answer: string;
}
const { question, answer } = Astro.props;
---

<details class="group border-b border-slate-200 last:border-0">
  <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none select-none">
    <h3 class="font-display font-semibold text-slate-900 text-base group-open:text-orange-500 transition-colors pr-4">
      {question}
    </h3>
    <span class="faq-arrow shrink-0 w-8 h-8 bg-slate-100 group-open:bg-orange-50 rounded-lg flex items-center justify-center text-slate-500 group-open:text-orange-500 transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </span>
  </summary>
  <div class="pb-5 pr-12">
    <p class="text-slate-500 text-sm leading-relaxed">{answer}</p>
  </div>
</details>

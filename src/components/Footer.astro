---
import { site } from '../data/site.ts';
---

<footer class="bg-navy-950 border-t border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-1 mb-4">
          <span class="font-display font-bold text-2xl text-gold-400">King</span>
          <span class="font-display font-bold text-2xl text-white">Ash</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          AI-powered marketing for local brick-and-mortar businesses. We help you outrank, automate, and dominate your local market.
        </p>
        <div class="flex items-center gap-3">
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="p-2 bg-white/5 hover:bg-gold-500/20 hover:text-gold-400 text-slate-400 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="p-2 bg-white/5 hover:bg-gold-500/20 hover:text-gold-400 text-slate-400 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="p-2 bg-white/5 hover:bg-gold-500/20 hover:text-gold-400 text-slate-400 rounded-lg transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Company</h3>
        <ul class="space-y-3" role="list">
          <li><a href="/about" class="text-slate-400 hover:text-gold-400 text-sm transition-colors">About Us</a></li>
          <li><a href="/services" class="text-slate-400 hover:text-gold-400 text-sm transition-colors">Services</a></li>
          <li><a href="/pricing" class="text-slate-400 hover:text-gold-400 text-sm transition-colors">Pricing</a></li>
          <li><a href="/blog" class="text-slate-400 hover:text-gold-400 text-sm transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-slate-400 hover:text-gold-400 text-sm transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Services Links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Services</h3>
        <ul class="space-y-3" role="list">
          {site.services.map((s) => (
            <li>
              <a href={`/services/${s.slug}`} class="text-slate-400 hover:text-gold-400 text-sm transition-colors">
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Contact</h3>
        <ul class="space-y-3" role="list">
          <li>
            <a href={site.phoneHref} class="flex items-start gap-2 text-slate-400 hover:text-gold-400 text-sm transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0 group-hover:text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {site.phoneFormatted}
            </a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="flex items-start gap-2 text-slate-400 hover:text-gold-400 text-sm transition-colors group">
              <svg class="w-4 h-4 mt-0.5 shrink-0 group-hover:text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {site.email}
            </a>
          </li>
          <li>
            <span class="flex items-start gap-2 text-slate-400 text-sm">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {site.address.full}
            </span>
          </li>
        </ul>
        <div class="mt-6">
          <p class="text-xs text-slate-500 mb-2">Serving all of Canada</p>
          <div class="flex flex-wrap gap-1">
            {site.areas.slice(0, 6).map((area) => (
              <a href={`/areas/${area.slug}`} class="text-xs text-slate-500 hover:text-gold-400 transition-colors">
                {area.name}
              </a>
            ))}
            <span class="text-xs text-slate-600">& more</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-xs">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
      </p>
      <p class="text-slate-600 text-xs">
        Built with Astro &amp; Tailwind CSS &mdash; Hosted on Cloudflare Pages
      </p>
    </div>
  </div>
</footer>

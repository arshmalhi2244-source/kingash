---
import { site } from '../data/site.ts';
---

<section id="hero" class="hero-space relative overflow-hidden min-h-[92vh] flex items-center">
  <!-- WebGL space-particle field -->
  <canvas id="hero-gl" class="hero-gl" aria-hidden="true"></canvas>

  <!-- Planets, spaceships, rockets, astronaut, UFO -->
  <div id="hero-scene" class="hero-scene" aria-hidden="true">
    <!-- shared gradient defs -->
    <svg width="0" height="0" style="position:absolute">
      <defs>
        <linearGradient id="trailG" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#d4af37" stop-opacity="0"></stop>
          <stop offset="1" stop-color="#f3da95" stop-opacity="0.9"></stop>
        </linearGradient>
        <linearGradient id="hullG" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#e4e4e7"></stop>
          <stop offset="1" stop-color="#9a9aa5"></stop>
        </linearGradient>
        <linearGradient id="bodyG" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#f0f0f3"></stop>
          <stop offset="1" stop-color="#a8a8b0"></stop>
        </linearGradient>
        <linearGradient id="flameG" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#fff3cf"></stop>
          <stop offset="0.4" stop-color="#f3da95"></stop>
          <stop offset="0.75" stop-color="#e8922c"></stop>
          <stop offset="1" stop-color="#e8922c" stop-opacity="0"></stop>
        </linearGradient>
        <radialGradient id="visorG" cx="0.4" cy="0.35" r="0.8">
          <stop offset="0" stop-color="#2b3a4a"></stop>
          <stop offset="0.6" stop-color="#14202e"></stop>
          <stop offset="1" stop-color="#3a2f14"></stop>
        </radialGradient>
      </defs>
    </svg>

    <div class="planet planet-giant"></div>
    <div class="planet-ring-wrap">
      <div class="planet-ring"></div>
      <div class="planet"></div>
    </div>
    <div class="planet planet-blue"></div>
    <div class="planet planet-red"></div>
    <div class="planet planet-moon"></div>
    <div class="planet planet-mini"></div>

    <!-- spaceship (large) — flies in beside the badge -->
    <svg class="ship ship-1" viewBox="0 0 120 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect class="trail" x="2" y="20" width="66" height="3.5" rx="1.75" fill="url(#trailG)"></rect>
      <path d="M70 22 L104 14 Q118 22 104 30 L70 22 Z" fill="url(#hullG)"></path>
      <path d="M78 22 L96 12 L100 15 L86 22 Z" fill="#c4c4cc"></path>
      <path d="M78 22 L96 32 L100 29 L86 22 Z" fill="#7d8290"></path>
      <circle cx="99" cy="22" r="3" fill="#f3da95"></circle>
      <circle cx="70" cy="22" r="4.2" fill="#e8c468"></circle>
    </svg>

    <!-- spaceship (smaller) — flies low behind the headline -->
    <svg class="ship ship-2" viewBox="0 0 120 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect class="trail" x="2" y="20" width="66" height="3.5" rx="1.75" fill="url(#trailG)"></rect>
      <path d="M70 22 L104 14 Q118 22 104 30 L70 22 Z" fill="url(#hullG)"></path>
      <path d="M78 22 L96 12 L100 15 L86 22 Z" fill="#c4c4cc"></path>
      <path d="M78 22 L96 32 L100 29 L86 22 Z" fill="#7d8290"></path>
      <circle cx="99" cy="22" r="3" fill="#f3da95"></circle>
      <circle cx="70" cy="22" r="4.2" fill="#e8c468"></circle>
    </svg>

    <!-- rocket launching upward -->
    <svg class="rocket" viewBox="0 0 60 132" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="flame" d="M22 92 Q30 134 38 92 Q30 100 22 92 Z" fill="url(#flameG)"></path>
      <path d="M30 6 L42 34 L18 34 Z" fill="#d4af37"></path>
      <rect x="18" y="32" width="24" height="60" rx="7" fill="url(#bodyG)"></rect>
      <circle cx="30" cy="52" r="7.5" fill="#0a1a2a"></circle>
      <circle cx="26.5" cy="49" r="2.4" fill="#3a5063" opacity="0.7"></circle>
      <circle cx="30" cy="52" r="7.5" fill="none" stroke="#e8c468" stroke-width="2"></circle>
      <path d="M18 82 L7 104 L18 95 Z" fill="#d4af37"></path>
      <path d="M42 82 L53 104 L42 95 Z" fill="#b8902c"></path>
    </svg>

    <!-- rocket (classic cartoon rocket-ship) -->
    <svg class="rocket-3" viewBox="0 0 64 150" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="flame" d="M24 94 Q32 142 40 94 Q32 102 24 94 Z" fill="url(#flameG)"></path>
      <path d="M32 4 C40 16 44 28 44 40 L20 40 C20 28 24 16 32 4 Z" fill="#e8922c"></path>
      <rect x="20" y="38" width="24" height="56" rx="11" fill="url(#bodyG)"></rect>
      <path d="M20 82 Q7 95 11 112 L20 99 Z" fill="#e8922c"></path>
      <path d="M44 82 Q57 95 53 112 L44 99 Z" fill="#b8902c"></path>
      <rect x="20" y="82" width="24" height="7" fill="#d4af37"></rect>
      <circle cx="32" cy="56" r="8" fill="#0a1a2a"></circle>
      <circle cx="28" cy="52.5" r="2.6" fill="#3a5063" opacity="0.7"></circle>
      <circle cx="32" cy="56" r="8" fill="none" stroke="#e8c468" stroke-width="2"></circle>
    </svg>

    <!-- floating astronaut (drifts toward the mouse) -->
    <div class="astro-wrap" id="hero-astro">
      <svg class="astro" viewBox="0 0 120 134" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="42" y="60" width="36" height="34" rx="10" fill="#b9bdc7"></rect>
        <rect x="47" y="64" width="26" height="11" rx="3" fill="#9a9aa5"></rect>
        <path d="M45 80 Q29 76 26 58" stroke="#e9e9ee" stroke-width="12" stroke-linecap="round"></path>
        <circle cx="26" cy="56" r="7" fill="#f4f4f6"></circle>
        <path d="M75 82 Q92 88 92 104" stroke="#e9e9ee" stroke-width="12" stroke-linecap="round"></path>
        <circle cx="92" cy="105" r="7" fill="#f4f4f6"></circle>
        <path d="M53 108 Q51 122 45 128" stroke="#e9e9ee" stroke-width="14" stroke-linecap="round"></path>
        <circle cx="44" cy="128" r="7" fill="#c4c4cc"></circle>
        <path d="M67 108 Q69 122 75 128" stroke="#e9e9ee" stroke-width="14" stroke-linecap="round"></path>
        <circle cx="76" cy="128" r="7" fill="#c4c4cc"></circle>
        <rect x="42" y="72" width="36" height="42" rx="16" fill="#f0f0f3"></rect>
        <path d="M61 72 Q78 75 78 98 L78 108 Q71 114 61 114 Z" fill="#dcdce1" opacity="0.7"></path>
        <rect x="51" y="85" width="18" height="13" rx="2.5" fill="#8a8f9a"></rect>
        <circle cx="55.5" cy="91.5" r="1.7" fill="#e8c468"></circle>
        <circle cx="60.5" cy="91.5" r="1.7" fill="#d4af37"></circle>
        <rect x="63.5" y="88.5" width="4" height="6" rx="1" fill="#c4c4cc"></rect>
        <circle cx="60" cy="44" r="30" fill="#f4f4f6"></circle>
        <circle cx="60" cy="44" r="30" fill="none" stroke="#c4c4cc" stroke-width="2"></circle>
        <ellipse cx="60" cy="45" rx="21" ry="18" fill="url(#visorG)"></ellipse>
        <ellipse cx="60" cy="45" rx="21" ry="18" fill="none" stroke="#e8c468" stroke-width="2.5"></ellipse>
        <ellipse cx="53" cy="39" rx="6.5" ry="4" fill="#ffffff" opacity="0.45" transform="rotate(-25 53 39)"></ellipse>
        <circle cx="67" cy="50" r="2.6" fill="#f3da95" opacity="0.55"></circle>
        <line x1="60" y1="15" x2="60" y2="21" stroke="#c4c4cc" stroke-width="2"></line>
        <circle cx="60" cy="12" r="2.6" fill="#e8c468"></circle>
      </svg>
    </div>

    <!-- cartoon UFO / flying saucer (hovers around) -->
    <svg class="ufo" viewBox="0 0 120 72" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="saucerG" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#ffffff"></stop><stop offset="1" stop-color="#b3b8c4"></stop>
        </linearGradient>
        <radialGradient id="domeG" cx="0.4" cy="0.30" r="0.9">
          <stop offset="0" stop-color="#f0feff"></stop><stop offset="0.55" stop-color="#7fd8e0"></stop><stop offset="1" stop-color="#3aa4ae"></stop>
        </radialGradient>
        <radialGradient id="ufoGlow" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0" stop-color="#ffe9a8" stop-opacity="0.8"></stop><stop offset="1" stop-color="#ffe9a8" stop-opacity="0"></stop>
        </radialGradient>
      </defs>
      <ellipse cx="60" cy="54" rx="44" ry="12" fill="url(#ufoGlow)"></ellipse>
      <ellipse cx="60" cy="46" rx="46" ry="13" fill="url(#saucerG)"></ellipse>
      <ellipse cx="60" cy="46" rx="46" ry="13" fill="none" stroke="#d4af37" stroke-width="2.5" opacity="0.75"></ellipse>
      <path d="M18 44 Q60 58 102 44" stroke="#b8902c" stroke-width="2" fill="none" opacity="0.6"></path>
      <g class="ufo-lights">
        <circle cx="28" cy="49" r="3.4" fill="#8afce8"></circle>
        <circle cx="44" cy="52" r="3.4" fill="#ffe9a8"></circle>
        <circle cx="60" cy="53" r="3.4" fill="#ffb877"></circle>
        <circle cx="76" cy="52" r="3.4" fill="#8afce8"></circle>
        <circle cx="92" cy="49" r="3.4" fill="#ffe9a8"></circle>
      </g>
      <path d="M38 44 A22 22 0 0 1 82 44 Z" fill="url(#domeG)"></path>
      <path d="M38 44 A22 22 0 0 1 82 44" fill="none" stroke="#e8c468" stroke-width="2.5"></path>
      <ellipse cx="52" cy="33" rx="6" ry="9" fill="#ffffff" opacity="0.4" transform="rotate(-18 52 33)"></ellipse>
    </svg>
  </div>

  <!-- readability layers -->
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="hero-vignette" aria-hidden="true"></div>

  <div class="relative z-[4] max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-4xl" id="hero-parallax">
      <!-- Label -->
      <div class="inline-flex items-center gap-2 bg-gold-500/10 border border-gold-500/20 text-gold-400 text-xs font-semibold px-4 py-2 rounded-full mb-8 uppercase tracking-wider">
        <span class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></span>
        AI-Powered Local Marketing
      </div>

      <!-- Headline -->
      <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white leading-[1.05] mb-6">
        <span class="block gradient-text">With us, your business runs 24/7</span>
        <span class="block">bringing in new customers, leads, and never missing a call.</span>
      </h1>

      <!-- Subtext (definition-first for GEO / AI search) -->
      <p class="text-slate-400 text-lg sm:text-xl max-w-2xl leading-relaxed mb-10">
        <strong class="text-slate-200 font-semibold">KingAsh is a marketing agency in {site.address.city}, {site.address.province}</strong> that helps local businesses grow with AI-powered websites, phone agents, ads, and local SEO. We build the digital systems that help brick-and-mortar businesses across {site.serviceArea} outcompete anyone online — all under one roof.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-14">
        <a
          href="/contact"
          class="inline-flex items-center justify-center gap-2 bg-gold-500 hover:bg-gold-600 text-navy-950 font-semibold text-base px-8 py-4 rounded-xl transition-all duration-200 shadow-lg shadow-gold-500/30 hover:shadow-gold-500/50 hover:scale-[1.02]"
        >
          Get Your Free Growth Plan
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-white hover:bg-white/5 font-semibold text-base px-8 py-4 rounded-xl transition-all duration-200"
        >
          See Our Services
        </a>
      </div>

      <!-- Trust Bar -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5 text-sm text-slate-400">
        <div class="flex items-center gap-2">
          <div class="flex text-gold-400">
            {Array(5).fill(null).map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span>4.9 / 5 from 120+ reviews</span>
        </div>
        <div class="hidden sm:block w-px h-4 bg-slate-700"></div>
        <span>150+ local businesses helped</span>
        <div class="hidden sm:block w-px h-4 bg-slate-700"></div>
        <span>No long-term contracts</span>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var canvas = document.getElementById('hero-gl');
    var heroEl = document.getElementById('hero');
    var parallax = document.getElementById('hero-parallax');
    var scene = document.getElementById('hero-scene');
    var astro = document.getElementById('hero-astro');
    if (!canvas) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var vertSrc = [
      'attribute vec3 a;',
      'uniform float u_time; uniform vec2 u_mouse; uniform vec2 u_res; uniform float u_dpr;',
      'varying float v_alpha; varying float v_glow; varying float v_arm;',
      'void main(){',
      '  float t = u_time * 0.16;',
      '  float px = (a.x - 0.5) * 9.0;',
      '  float py = (a.y - 0.5) * 6.5;',
      '  float seed = a.z * 53.0;',
      '  float pz = mod(a.z * 9.0 - t * 1.1, 9.0) + 0.8;',
      '  px += sin(t * 0.9 + seed) * 0.35;',
      '  py += cos(t * 0.7 + seed * 1.7) * 0.35;',
      '  vec3 P = vec3(px, py, pz);',
      '  P.xy += u_mouse * vec2(0.9, 0.6) * (P.z * 0.10);',
      '  float focal = 1.7;',
      '  vec2 sp = P.xy * focal / P.z;',
      '  sp.x *= u_res.y / u_res.x;',
      '  gl_Position = vec4(sp, 0.0, 1.0);',
      '  float near = 1.0 - smoothstep(0.8, 9.0, P.z);',
      '  float tw = 0.75 + 0.25 * sin(t * 6.0 + seed);',
      '  gl_PointSize = mix(1.2, 8.0, near) * tw * u_dpr;',
      '  v_glow = near; v_arm = a.x; v_alpha = mix(0.12, 1.0, near) * tw;',
      '}'
    ].join('\n');

    var fragSrc = [
      'precision highp float;',
      'varying float v_alpha; varying float v_glow; varying float v_arm;',
      'void main(){',
      '  vec2 uv = gl_PointCoord - 0.5;',
      '  float d = length(uv);',
      '  float core = smoothstep(0.5, 0.0, d);',
      '  float halo = smoothstep(0.5, 0.15, d) * 0.5;',
      '  float mask = core + halo;',
      '  vec3 gold = vec3(1.0, 0.72, 0.26);',
      '  vec3 silver = vec3(0.78, 0.80, 0.90);',
      '  vec3 hot = vec3(1.0, 0.95, 0.78);',
      '  vec3 col = mix(gold, silver, smoothstep(0.55, 1.0, v_arm) * 0.5);',
      '  col = mix(col, hot, v_glow * v_glow);',
      '  float a = mask * v_alpha;',
      '  gl_FragColor = vec4(col, a);',
      '}'
    ].join('\n');

    var gl = null;
    try { gl = canvas.getContext('webgl', { alpha: false, antialias: true }) || canvas.getContext('experimental-webgl'); } catch (e) {}
    if (!gl) { canvas.style.display = 'none'; return; }

    function sh(type, src) {
      var s = gl.createShader(type); gl.shaderSource(s, src); gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) console.error(gl.getShaderInfoLog(s));
      return s;
    }
    var prog = gl.createProgram();
    gl.attachShader(prog, sh(gl.VERTEX_SHADER, vertSrc));
    gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fragSrc));
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) { canvas.style.display = 'none'; return; }
    gl.useProgram(prog);

    var N = 6500;
    var data = new Float32Array(N * 3);
    for (var i = 0; i < N; i++) { data[i * 3] = Math.random(); data[i * 3 + 1] = Math.random(); data[i * 3 + 2] = Math.random(); }
    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, data, gl.STATIC_DRAW);
    var loc = gl.getAttribLocation(prog, 'a');
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 3, gl.FLOAT, false, 0, 0);

    var uTime = gl.getUniformLocation(prog, 'u_time');
    var uMouse = gl.getUniformLocation(prog, 'u_mouse');
    var uRes = gl.getUniformLocation(prog, 'u_res');
    var uDpr = gl.getUniformLocation(prog, 'u_dpr');

    gl.disable(gl.DEPTH_TEST);
    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE);

    var dpr = Math.min(window.devicePixelRatio || 1, 1.75);
    function resize() {
      var r = canvas.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 1.75);
      canvas.width = Math.floor(r.width * dpr);
      canvas.height = Math.floor(r.height * dpr);
      gl.viewport(0, 0, canvas.width, canvas.height);
    }
    window.addEventListener('resize', resize); resize();

    var mx = 0, my = 0, tmx = 0, tmy = 0;
    window.addEventListener('pointermove', function (e) {
      tmx = (e.clientX / window.innerWidth) * 2 - 1;
      tmy = -((e.clientY / window.innerHeight) * 2 - 1);
    }, { passive: true });

    var running = true;
    var io = new IntersectionObserver(function (es) { running = es[0].isIntersecting; if (running && !reduce) requestAnimationFrame(loop); }, { threshold: 0.01 });
    io.observe(heroEl);
    document.addEventListener('visibilitychange', function () { running = !document.hidden; if (running && !reduce) requestAnimationFrame(loop); });

    var start = performance.now();
    function render(now) {
      var t = (now - start) / 1000;
      mx += (tmx - mx) * 0.05; my += (tmy - my) * 0.05;
      gl.clearColor(0.02, 0.02, 0.02, 1.0); gl.clear(gl.COLOR_BUFFER_BIT);
      gl.uniform1f(uTime, t);
      gl.uniform2f(uMouse, mx, my);
      gl.uniform2f(uRes, canvas.width, canvas.height);
      gl.uniform1f(uDpr, dpr);
      gl.drawArrays(gl.POINTS, 0, N);
      if (parallax) parallax.style.transform = 'translate3d(' + (-mx * 10) + 'px,' + (my * 8) + 'px,0)';
      if (scene) scene.style.transform = 'translate3d(' + (mx * 22) + 'px,' + (my * 16) + 'px,0)';
      if (astro) astro.style.transform = 'translate3d(' + (mx * 72) + 'px,' + (-my * 56) + 'px,0)';
    }
    function loop(now) { if (!running || reduce) return; render(now); requestAnimationFrame(loop); }
    if (reduce) { resize(); render(performance.now()); } else { requestAnimationFrame(loop); }
  })();
</script>

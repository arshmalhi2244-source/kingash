---
interface Props {
  name: string;
  price: string;
  period: string;
  description: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
}
const { name, price, period, description, features, cta, ctaHref, featured = false } = Astro.props;
---

<article class:list={[
  'relative rounded-2xl p-8 flex flex-col gap-6 card-hover',
  featured
    ? 'bg-navy-950 border-2 border-gold-500 shadow-xl shadow-gold-500/10'
    : 'bg-navy-900 border border-white/10'
]}>
  {featured && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="bg-gold-500 text-navy-950 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider">
        Most Popular
      </span>
    </div>
  )}

  <!-- Header -->
  <div>
    <h3 class="font-display font-bold text-xl mb-1 text-white">
      {name}
    </h3>
    <p class="text-sm text-slate-400">
      {description}
    </p>
  </div>

  <!-- Price -->
  <div class="flex items-end gap-1">
    <span class="font-display font-bold text-5xl text-white">
      {price}
    </span>
    <span class="text-sm mb-2 text-slate-400">
      {period}
    </span>
  </div>

  <!-- Features -->
  <ul class="flex flex-col gap-3 flex-1" role="list">
    {features.map((feature) => (
      <li class="flex items-start gap-3">
        <svg class="w-5 h-5 text-gold-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span class="text-sm text-slate-300">
          {feature}
        </span>
      </li>
    ))}
  </ul>

  <!-- CTA -->
  <a
    href={ctaHref}
    class:list={[
      'w-full text-center font-semibold text-sm py-3.5 rounded-xl transition-all duration-200',
      featured
        ? 'bg-gold-500 hover:bg-gold-600 text-navy-950 shadow-lg shadow-gold-500/30'
        : 'bg-white/10 hover:bg-white/20 text-white'
    ]}
  >
    {cta}
  </a>
</article>

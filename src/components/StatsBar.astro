---
import { site } from '../data/site.ts';
---

<section class="bg-slate-950 border-y border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <dl class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 lg:divide-x lg:divide-white/[0.08]">
      {site.stats.map((stat, i) => (
        <div class={`flex flex-col items-center text-center lg:px-8 reveal reveal-delay-${i + 1}`}>
          <dt class="font-display font-bold text-4xl sm:text-5xl text-orange-500 mb-1">
            {stat.value}
          </dt>
          <dd class="text-slate-400 text-sm font-medium">{stat.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

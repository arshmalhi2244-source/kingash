---
interface Props {
  quote: string;
  name: string;
  business: string;
  initials: string;
  rating: number;
}
const { quote, name, business, initials, rating } = Astro.props;
---

<article class="bg-navy-900 border border-white/10 rounded-2xl p-7 flex flex-col gap-5 card-hover">
  <!-- Stars -->
  <div class="flex gap-0.5" aria-label={`${rating} out of 5 stars`}>
    {Array(rating).fill(null).map(() => (
      <svg class="w-5 h-5 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <blockquote class="text-slate-300 text-sm leading-relaxed flex-1">
    &ldquo;{quote}&rdquo;
  </blockquote>

  <!-- Author -->
  <div class="flex items-center gap-3 pt-4 border-t border-white/10">
    <div class="w-10 h-10 bg-gradient-to-br from-gold-400 to-gold-600 rounded-full flex items-center justify-center text-white font-bold text-sm shrink-0">
      {initials}
    </div>
    <div>
      <p class="font-semibold text-white text-sm">{name}</p>
      <p class="text-slate-400 text-xs">{business}</p>
    </div>
  </div>
</article>

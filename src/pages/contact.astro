---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.website },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${site.website}/contact` }
  ]
};
---

<BaseLayout
  title="Contact KingAsh — Get Your Free Growth Plan"
  description="Get in touch with KingAsh Marketing Agency. We respond within 1 business day. Phone: (236) 380-5700. Email: arshmalhi2244@gmail.com. Surrey, BC."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden py-24 lg:py-28">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/3 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Home</a></li>
          <li class="text-slate-700">/</li>
          <li class="text-slate-300">Contact</li>
        </ol>
      </nav>
      <div class="max-w-2xl">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Get in Touch</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mt-3 mb-5">
          Let's Grow Your <span class="gradient-text">Business Together</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed">
          Tell us about your business and goals. We'll put together a free, no-obligation growth plan within 24 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="font-display font-bold text-2xl text-white mb-6">Contact Information</h2>
            <div class="space-y-5">
              <a href={site.phoneHref} class="flex items-center gap-4 group">
                <div class="w-12 h-12 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-400 shrink-0 group-hover:bg-gold-500 group-hover:text-navy-950 transition-colors">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-400 mb-0.5">Phone</p>
                  <p class="font-semibold text-white group-hover:text-gold-400 transition-colors">{site.phoneFormatted}</p>
                </div>
              </a>
              <a href={`mailto:${site.email}`} class="flex items-center gap-4 group">
                <div class="w-12 h-12 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-400 shrink-0 group-hover:bg-gold-500 group-hover:text-navy-950 transition-colors">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-400 mb-0.5">Email</p>
                  <p class="font-semibold text-white group-hover:text-gold-400 transition-colors text-sm">{site.email}</p>
                </div>
              </a>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-400 shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-slate-400 mb-0.5">Location</p>
                  <p class="font-semibold text-white">{site.address.full}</p>
                  <p class="text-xs text-slate-400">Serving all of Canada</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Response time promise -->
          <div class="bg-gold-500/10 border border-gold-500/20 rounded-2xl p-6">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-gold-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="font-semibold text-white text-sm">Response Time Promise</h3>
            </div>
            <p class="text-slate-300 text-sm leading-relaxed">
              We respond to every inquiry within <strong>1 business day</strong> — usually much faster. For urgent matters, call us directly.
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            class="bg-navy-900 border border-white/10 rounded-2xl p-8"
            novalidate
          >
            <h2 class="font-display font-bold text-2xl text-white mb-6">Get Your Free Growth Plan</h2>

            <div class="grid sm:grid-cols-2 gap-5 mb-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-300 mb-1.5">Full Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Jane Smith"
                  class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm transition-shadow"
                />
              </div>
              <div>
                <label for="business" class="block text-sm font-medium text-slate-300 mb-1.5">Business Name *</label>
                <input
                  type="text"
                  id="business"
                  name="business"
                  required
                  placeholder="Jane's Bakery"
                  class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm transition-shadow"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5 mb-5">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-300 mb-1.5">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@example.com"
                  class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm transition-shadow"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-300 mb-1.5">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  placeholder="(604) 555-0100"
                  class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm transition-shadow"
                />
              </div>
            </div>

            <div class="mb-5">
              <label for="service" class="block text-sm font-medium text-slate-300 mb-1.5">Service You're Interested In</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm transition-shadow"
              >
                <option value="">Select a service...</option>
                {site.services.map((s) => (
                  <option value={s.slug}>{s.name}</option>
                ))}
                <option value="all">All Services / Not Sure Yet</option>
              </select>
            </div>

            <div class="mb-6">
              <label for="message" class="block text-sm font-medium text-slate-300 mb-1.5">Tell Us About Your Business *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                placeholder="What type of business do you run? What are your main goals? Any current challenges?"
                class="w-full px-4 py-3 bg-navy-950 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-transparent text-sm resize-none transition-shadow"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-gold-500 hover:bg-gold-600 text-navy-950 font-semibold text-base py-4 rounded-xl transition-colors duration-200 shadow-lg shadow-gold-500/20 flex items-center justify-center gap-2"
            >
              Send My Free Growth Plan Request
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </button>
            <p class="text-center text-xs text-slate-400 mt-3">No spam. No pressure. We'll be in touch within 1 business day.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
import { site } from '../data/site.ts';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "MarketingAgency",
    "name": site.name,
    "description": site.description,
    "url": site.website,
    "telephone": `+1${site.phone}`,
    "email": site.email,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": site.address.city,
      "addressRegion": site.address.province,
      "addressCountry": "CA"
    },
    "areaServed": "Canada",
    "priceRange": "$$",
    "founder": { "@type": "Person", "name": site.owner.name },
    "sameAs": [site.social.instagram, site.social.facebook, site.social.linkedin]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": site.faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": site.website }]
  }
];

const howItWorks = [
  {
    step: "01",
    title: "Free Strategy Call",
    desc: "We spend 30 minutes learning about your business, your goals, and your biggest challenges. No pitch. No pressure."
  },
  {
    step: "02",
    title: "Custom Growth Plan",
    desc: "We build a tailored plan showing exactly which services will drive the most results for your specific business and market."
  },
  {
    step: "03",
    title: "Launch & Scale",
    desc: "We execute the plan, you watch your phone ring and your revenue grow. Simple monthly reports keep you in the loop."
  }
];

const whyUs = [
  {
    title: "Specialists in Local",
    desc: "We only work with brick-and-mortar businesses. We know what works for restaurants, salons, trades, and retail — because that's all we do.",
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`
  },
  {
    title: "AI Gives You the Edge",
    desc: "We use AI tools to deliver enterprise-level results at a fraction of the cost. Your competitors can't keep up.",
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`
  },
  {
    title: "No Vanity Metrics",
    desc: "We track revenue and real leads — not likes and impressions. If it's not making you money, we change the strategy.",
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`
  },
  {
    title: "Month-to-Month",
    desc: "No 12-month lock-ins. We earn your business every single month by delivering results. Cancel anytime with 30 days notice.",
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
  }
];
---

<BaseLayout
  title="KingAsh Marketing Agency — Outrank. Automate. Dominate."
  description="KingAsh is a marketing agency in Surrey, BC that helps local businesses grow with AI-powered websites, phone agents, ads, and local SEO. Serving the Lower Mainland, starting at $100. Get your free growth plan today."
  schema={schema}
>
  <!-- Hero -->
  <Hero />

  <!-- Stats -->
  <StatsBar />

  <!-- Services -->
  <section class="bg-navy-900 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-wider">What We Do</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          Everything Your Business Needs to Win Online
        </h2>
        <p class="text-slate-400 max-w-2xl mx-auto">
          Proven services. One agency. Zero fluff. Every service is designed to bring more customers through your door.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {site.services.map((service, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <ServiceCard
              slug={service.slug}
              name={service.name}
              shortDesc={service.shortDesc}
              icon={service.icon}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-wider">The Process</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          From First Call to First Results
        </h2>
        <p class="text-slate-400 max-w-xl mx-auto">
          Getting started is easier than you think. Three steps and you're growing.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 relative">
        <!-- Connector line -->
        <div class="hidden md:block absolute top-12 left-[16.66%] right-[16.66%] h-px bg-gradient-to-r from-gold-500/10 via-gold-400/60 to-gold-500/10" aria-hidden="true"></div>
        {howItWorks.map((step, i) => (
          <div class={`relative text-center reveal reveal-delay-${i + 1}`}>
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gold-500 text-navy-950 font-display font-bold text-xl rounded-2xl mb-5 mx-auto shadow-lg shadow-gold-500/30">
              {step.step}
            </div>
            <h3 class="font-display font-bold text-xl text-white mb-3">{step.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="bg-navy-900 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Why KingAsh</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          We're Different. Here's How.
        </h2>
        <p class="text-slate-400 max-w-xl mx-auto">
          Dozens of agencies want your money. We want your results. Those are very different motivations.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {whyUs.map((item, i) => (
          <div class={`flex gap-5 bg-white/5 border border-white/[0.08] rounded-2xl p-7 hover:border-gold-500/30 transition-colors reveal reveal-delay-${i + 1}`}>
            <div class="w-12 h-12 bg-gold-500/10 border border-gold-500/20 rounded-xl flex items-center justify-center text-gold-400 shrink-0">
              <div class="w-6 h-6" set:html={item.icon} />
            </div>
            <div>
              <h3 class="font-display font-semibold text-white text-lg mb-2">{item.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-wider">Client Stories</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          Real Businesses. Real Results.
        </h2>
        <p class="text-slate-400 max-w-xl mx-auto">
          Don't take our word for it. Here's what local business owners say after working with KingAsh.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {site.testimonials.map((t, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <TestimonialCard
              quote={t.quote}
              name={t.name}
              business={t.business}
              initials={t.initials}
              rating={t.rating}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-navy-900 py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-400 font-semibold text-sm uppercase tracking-wider">FAQ</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          Got Questions? We've Got Answers.
        </h2>
      </div>
      <div class="divide-y divide-white/10 border border-white/10 rounded-2xl px-6 reveal">
        {site.faqs.map((faq) => (
          <FAQAccordion question={faq.q} answer={faq.a} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection />
</BaseLayout>

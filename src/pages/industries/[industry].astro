---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';
import { site } from '../../data/site.ts';

export function getStaticPaths() {
  return site.industries.map((industry) => ({
    params: { industry: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": `${industry.name} Marketing`,
    "provider": {
      "@type": "LocalBusiness",
      "name": site.name,
      "telephone": `+1${site.phone}`,
      "email": site.email,
      "url": site.website,
    },
    "areaServed": { "@type": "Country", "name": "Canada" },
    "description": `${site.name} provides website design, AI phone representatives, Meta ads, and local SEO built specifically for ${industry.name.toLowerCase()}.`,
    "url": `${site.website}/industries/${industry.slug}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": industry.faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.website },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": `${site.website}/industries` },
      { "@type": "ListItem", "position": 3, "name": industry.name, "item": `${site.website}/industries/${industry.slug}` }
    ]
  }
];
---

<BaseLayout
  title={`Marketing for ${industry.name} | KingAsh`}
  description={`${industry.name} ${industry.keyword.includes('marketing') ? 'marketing' : 'marketing'} that fills your calendar. Websites, local SEO, Meta ads, and 24/7 AI phone reps built for ${industry.name.toLowerCase()}. Vancouver, BC & all of Canada.`}
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden py-24 lg:py-28">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 right-1/3 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Home</a></li>
          <li class="text-slate-700">/</li>
          <li><a href="/industries" class="hover:text-gold-400 transition-colors">Industries</a></li>
          <li class="text-slate-700">/</li>
          <li class="text-slate-300">{industry.name}</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-gold-500/10 border border-gold-500/20 text-gold-400 text-xs font-semibold px-4 py-2 rounded-full mb-6 uppercase tracking-wider">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Built for {industry.name}
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white mt-2 mb-5">
          Marketing for <span class="gradient-text">{industry.name}</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed mb-8">
          {industry.intro}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-gold-500 hover:bg-gold-600 text-navy-950 font-semibold px-8 py-4 rounded-xl transition-colors shadow-lg shadow-gold-500/30"
          >
            Get a Free Growth Plan for Your Business
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="bg-navy-950 py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Sound Familiar?</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-6">
            The Challenges {industry.name} Face
          </h2>
          <p class="text-slate-400 leading-relaxed mb-6">
            Generic marketing doesn't understand your business. We build every strategy around the real problems that keep {industry.name.toLowerCase()} up at night.
          </p>
          <ul class="space-y-3">
            {industry.painPoints.map((point) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-300">
                <svg class="w-4 h-4 text-gold-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
                {point}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-navy-900 border border-gold-500/20 rounded-2xl p-8 text-center reveal reveal-delay-2">
          <p class="text-gold-500 font-semibold text-sm uppercase tracking-wider mb-3">Real Result</p>
          <p class="font-display font-bold text-6xl text-white mb-2">{industry.result.value}</p>
          <p class="text-slate-400">{industry.result.label}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How We Help (industry-specific tactics) -->
  <section class="bg-navy-900 py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Our Playbook</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          How We Grow {industry.name}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-5">
        {industry.tactics.map((tactic, i) => (
          <div class={`bg-navy-950 border border-white/10 rounded-2xl p-7 card-hover reveal reveal-delay-${(i % 4) + 1}`}>
            <h3 class="font-display font-bold text-xl text-white mb-2">{tactic.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{tactic.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-navy-950 py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Everything Under One Roof</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2 mb-4">
          Our Services for {industry.name}
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {site.services.map((service, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <ServiceCard
              slug={service.slug}
              name={service.name}
              shortDesc={service.shortDesc}
              icon={service.icon}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-navy-900 py-20 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Questions</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2">
          {industry.name} FAQs
        </h2>
      </div>
      <div class="space-y-4">
        {industry.faqs.map((faq, i) => (
          <div class={`bg-navy-950 border border-white/10 rounded-2xl p-6 reveal reveal-delay-${(i % 4) + 1}`}>
            <h3 class="font-semibold text-white mb-2">{faq.q}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Industries -->
  <section class="bg-navy-950 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-xl text-white mb-6">We Also Work With</h2>
      <div class="flex flex-wrap gap-3">
        {site.industries
          .filter((ind) => ind.slug !== industry.slug)
          .map((ind) => (
            <a
              href={`/industries/${ind.slug}`}
              class="text-sm text-slate-300 hover:text-gold-400 bg-navy-900 hover:bg-gold-500/10 border border-white/10 hover:border-gold-500/30 px-4 py-2 rounded-lg transition-colors"
            >
              {ind.name}
            </a>
          ))}
      </div>
    </div>
  </section>

  <CTASection
    headline={`Ready to Grow Your ${industry.name} Business?`}
    subtext={`Join local businesses across Canada that trust KingAsh with their digital growth. Get your free plan — no commitment.`}
  />
</BaseLayout>

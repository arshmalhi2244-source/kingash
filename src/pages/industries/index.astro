---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { site } from '../../data/site.ts';

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": site.website },
    { "@type": "ListItem", "position": 2, "name": "Industries", "item": `${site.website}/industries` }
  ]
};
---

<BaseLayout
  title="Industries We Serve | Marketing for Local Businesses | KingAsh"
  description="KingAsh builds marketing that fits your trade — restaurants, salons, plumbers, electricians, dentists, gyms, auto shops, and real estate. Websites, SEO, ads, and AI phone reps."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden py-24 lg:py-28">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 right-1/3 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Home</a></li>
          <li class="text-slate-700">/</li>
          <li class="text-slate-300">Industries</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Industries We Serve</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white mt-3 mb-5">
          Marketing Built for <span class="gradient-text">Your Trade</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed">
          We don't do one-size-fits-all. Every strategy is tuned to how customers actually find and choose businesses like yours. Find your industry below.
        </p>
      </div>
    </div>
  </section>

  <!-- Industries Grid -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {site.industries.map((industry, i) => (
          <a
            href={`/industries/${industry.slug}`}
            class={`group block bg-navy-900 border border-white/10 hover:border-gold-500/40 rounded-2xl p-7 card-hover reveal reveal-delay-${(i % 4) + 1}`}
          >
            <div class="flex items-center justify-between mb-3">
              <h2 class="font-display font-bold text-xl text-white group-hover:text-gold-400 transition-colors">{industry.name}</h2>
              <span class="font-display font-bold text-gold-500 text-lg">{industry.result.value}</span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">{industry.intro}</p>
            <span class="inline-flex items-center gap-2 text-gold-400 text-sm font-semibold">
              See our {industry.name.toLowerCase()} playbook
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <p class="text-slate-500 text-sm text-center mt-12">
        Don't see your industry? We work with all local brick-and-mortar businesses.
        <a href="/contact" class="text-gold-400 hover:text-gold-300 transition-colors">Get in touch</a> and we'll build a plan for you.
      </p>
    </div>
  </section>

  <CTASection
    headline="Let's Grow Your Business"
    subtext="Book a free 30-minute strategy call and we'll show you exactly how we'd market a business like yours."
  />
</BaseLayout>

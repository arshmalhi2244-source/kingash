---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { site } from '../../data/site.ts';

const stats = [
  { value: 30, suffix: "+", label: "Local Businesses Grown" },
  { value: 247, suffix: "%", label: "Avg Traffic Growth" },
  { value: 3, suffix: "×", label: "Avg Lead Increase" },
  { value: 60, suffix: "s", label: "Missed-Call Response" },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.website },
      { "@type": "ListItem", "position": 2, "name": "Results", "item": `${site.website}/results` }
    ]
  }
];
---

<BaseLayout
  title="Case Studies & Results | Real Local Business Growth | KingAsh"
  description="See the kind of growth KingAsh builds for local businesses — more reservations, recovered calls, page-one rankings, and new patients. Vancouver, BC & all of Canada."
  schema={schema}
>
  <!-- Hero -->
  <section class="hero-bg relative overflow-hidden py-24 lg:py-28">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 right-1/3 w-72 h-72 bg-gold-500/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-gold-400 transition-colors">Home</a></li>
          <li class="text-slate-700">/</li>
          <li class="text-slate-300">Results</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">Case Studies</span>
        <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white mt-3 mb-5">
          Growth We Can <span class="gradient-text">Prove</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed">
          We measure our work in bookings, calls, and rankings — not impressions. Below are representative examples of the kind of growth we build for local businesses across the Lower Mainland and beyond.
        </p>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        {site.caseStudies.map((cs, i) => (
          <article class={`bg-navy-900 border border-white/10 rounded-2xl p-8 lg:p-10 reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="grid lg:grid-cols-2 gap-10 items-center">
              <!-- Left: context + result -->
              <div>
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <span class="inline-flex items-center bg-gold-500/10 border border-gold-500/20 text-gold-400 text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wider">
                    {cs.industry}
                  </span>
                  <span class="inline-flex items-center gap-1.5 text-slate-500 text-xs font-medium">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    {cs.location}
                  </span>
                </div>
                <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-4">{cs.headline}</h2>
                <p class="text-slate-400 leading-relaxed mb-6">{cs.summary}</p>
                <div class="flex flex-wrap gap-2">
                  {cs.services.map((s) => (
                    <span class="text-xs text-slate-300 bg-navy-950 border border-white/10 px-3 py-1.5 rounded-lg">{s}</span>
                  ))}
                </div>
              </div>

              <!-- Right: animated timeline -->
              <div class="bg-navy-950 border border-gold-500/20 rounded-2xl p-7">
                <p class="text-gold-500 font-semibold text-xs uppercase tracking-wider mb-6 text-center">{cs.metric}</p>
                <div class="flex items-end justify-between gap-2">
                  {cs.timeline.map((point, j) => (
                    <>
                      {j > 0 && (
                        <div class="flex-1 h-px bg-gradient-to-r from-white/10 to-gold-500/40 mb-6" aria-hidden="true"></div>
                      )}
                      <div class="text-center shrink-0">
                        <p
                          class="font-display font-bold text-3xl sm:text-4xl text-white counter"
                          data-count={point.value}
                        >0</p>
                        <p class="text-slate-500 text-xs mt-1 whitespace-nowrap">{point.label}</p>
                      </div>
                    </>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-navy-900 py-16 lg:py-20 border-y border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((stat, i) => (
          <div class={`text-center reveal reveal-delay-${i + 1}`}>
            <p
              class="font-display font-bold text-4xl sm:text-5xl text-gold-500 counter"
              data-count={stat.value}
              data-suffix={stat.suffix}
            >0</p>
            <p class="text-slate-400 text-sm mt-2">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-navy-950 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="text-gold-500 font-semibold text-sm uppercase tracking-wider">In Their Words</span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-white mt-2">What Our Clients Say</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {site.testimonials.map((t, i) => (
          <div class={`bg-navy-900 border border-white/10 rounded-2xl p-7 reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="flex gap-1 mb-4" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.447a1 1 0 00-.363 1.118l1.287 3.958c.3.922-.755 1.688-1.539 1.118l-3.366-2.447a1 1 0 00-1.176 0l-3.366 2.447c-.783.57-1.838-.196-1.538-1.118l1.286-3.958a1 1 0 00-.363-1.118L2.98 9.385c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.286-3.958z" />
                </svg>
              ))}
            </div>
            <p class="text-slate-300 text-sm leading-relaxed mb-6">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-gold-400 to-gold-600 rounded-xl flex items-center justify-center text-navy-950 font-display font-bold text-sm shrink-0">
                {t.initials}
              </div>
              <div>
                <p class="font-semibold text-white text-sm">{t.name}</p>
                <p class="text-slate-500 text-xs">{t.business}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to Be Our Next Success Story?"
    subtext="Book a free growth audit and we'll show you exactly how we'd get results like these for a business like yours."
  />
</BaseLayout>

<script>
  const counters = document.querySelectorAll<HTMLElement>('.counter');
  const io = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseFloat(el.dataset.count || '0');
      const suffix = el.dataset.suffix || '';
      const duration = 1400;
      const start = performance.now();
      function tick(now: number) {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(target * eased).toString() + suffix;
        if (p < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = target.toString() + suffix;
        }
      }
      requestAnimationFrame(tick);
      io.unobserve(el);
    });
  }, { threshold: 0.4 });
  counters.forEach((c) => io.observe(c));
</script>
